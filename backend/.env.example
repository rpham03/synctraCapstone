DATABASE_URL=postgresql://user:password@localhost:5432/syntra
REDIS_URL=redis://localhost:6379
SECRET_KEY=change-me-in-production
CANVAS_API_TOKEN=your_canvas_token_here
# REST API root (must match the school’s Canvas host + /api/v1)
CANVAS_API_BASE_URL=https://canvas.uw.edu/api/v1
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Chat tab agent — default is local Ollama (free). Set CHAT_LLM_PROVIDER=openai to use OpenAI.
CHAT_LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# OpenAI (optional — requires API billing; ChatGPT Plus does not include this)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Supabase — Database for storing calendar events and tasks
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_key

# AI-powered course parsing (hybrid regex + Ollama)
# Ollama is completely free and private - no API keys needed!
# Just install Ollama and run: ollama serve
